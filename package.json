{
  "name": "cloud-portal",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "bun ./observability/dev-start.js",
    "start": "bun --smol ./observability/start.js",
    "preview": "NODE_ENV=production bun --bun ./server.ts",
    "lint": "eslint \"{app,lib}/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "typecheck": "react-router typegen && tsc",
    "clean": "rm -rf node_modules && rm -rf .react-router && rm -rf build",
    "openapi": "bun scripts/openapi.ts",
    "graphql": "bun run scripts/graphql.ts",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "start-server-and-test dev http://localhost:3000/_healthz 'cypress run'",
    "test:e2e:prod": "start-server-and-test 'bun run start' http://localhost:3000/_healthz 'cypress run --config-file cypress.config.ts --quiet'",
    "test:e2e:preview": "cypress run --config-file cypress.config.ts --quiet",
    "test:e2e:debug": "start-server-and-test 'bun run start' http://localhost:3000/_healthz 'cypress open'",
    "test:unit:prod": "cypress run --component --config-file cypress.config.ts --quiet",
    "test:unit:debug": "cypress open --component",
    "test:feature-flags": "bun test app/modules/feature-flags",
    "test:lib": "bun test app/lib",
    "test:rbac": "bun test app/modules/rbac",
    "test:coverage": "bun test --coverage"
  },
