# Dependencies — reinstalled inside the build stage
node_modules

# VCS history — 100+ MB, never needed at runtime
.git
.gitignore

# Build outputs — regenerated by `bun run build` inside the image
build

# Tests, coverage and E2E assets — not part of the runtime image
cypress
cypress.config.ts
coverage
.nyc_output

# Local env / secrets
.env
.env.*

# Docs and meta
docs
*.md
LICENSE

# CI / tooling config not needed at runtime
.github
.vscode
.cursor
.husky

# Caches and logs
.cache
*.log
