{
  "name": "@datum-cloud/sample-portal-plugin",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Reference Portal Plugin: a Module Federation remote + tiny backend exercising every v1 extension point (nav, page, home card) plus proxied data (declared backend + Milo control plane).",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"bun run backend/server.ts\"",
    "preview": "concurrently -k -n web,api -c cyan,magenta \"vite preview\" \"bun run backend/server.ts\"",
    "preview:web": "vite preview",
    "backend": "bun run backend/server.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@datum-cloud/datum-ui": "^1.3.2",
    "@tanstack/react-query": "^5.101.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.0"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.16.16",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
